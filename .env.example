# 校园电量接口
GUET_BASE_URL=http://sdcx.guet.edu.cn
GUET_ROOM_NO=y503616
GUET_QUERY_COUNT=10
GUET_ELECTRICITY_THRESHOLD=20
GUET_REQUEST_TIMEOUT=20
GUET_REQUEST_RETRIES=3

# 初始 Cookie。可从浏览器或 Reqable 的成功请求中复制完整 Cookie。
# 可以暂时留空；无可用 Cookie 时程序会自动启动 Chrome 刷新会话。
GUET_ELECTRICITY_COOKIE=

# 浏览器刷新后的 Cookie
GUET_COOKIE_FILE=./data/guet-cookies.json

# Playwright 专用 Chrome 用户目录
GUET_BROWSER_PROFILE_DIR=./data/guet-chrome-profile

# 调用电脑中安装的 Google Chrome
GUET_BROWSER_CHANNEL=chrome

# 隐藏 Chrome，不显示浏览器窗口
GUET_BROWSER_HEADLESS=true

# 整个验证过程的最长等待时间
GUET_VERIFICATION_WAIT_SECONDS=90

# 检测脚本执行后，等待多少秒再主动重新访问 /yd
GUET_VERIFICATION_RELOAD_DELAY_SECONDS=7

# QQ 邮箱 SMTP
QQ_SMTP_HOST=smtp.qq.com
QQ_SMTP_PORT=465
QQ_SMTP_TIMEOUT=30
QQ_EMAIL=你的QQ邮箱@qq.com
QQ_AUTH_CODE=QQ邮箱生成的SMTP授权码

# 接收提醒的邮箱，可以与发件QQ邮箱相同
ALERT_TO_EMAIL=你的收件邮箱

# 邮件主题在代码中固定为：
# [宿舍电量监控] 低电量提醒

# 本地状态与日志
STATE_FILE=./data/state.json
LOG_FILE=./logs/electricity-monitor.log
